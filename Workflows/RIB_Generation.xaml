  <Sequence DisplayName="RIB_Generation" sap:VirtualizedContainerService.HintSize="496,1000" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="str_Template" />
      <Variable x:TypeArguments="x:String" Name="str_FinalRIB" />
    </Sequence.Variables>
    <sap:WorkflowViewStateService.ViewState>
