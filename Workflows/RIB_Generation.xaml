      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[str_Template.Replace("{{NOM}}", in_Nom).Replace("{{PRENOM}}", in_Prenom).Replace("{{CIN}}", in_CINNum).Replace("{{NUM_COMPTE}}", in_NumCompte).Replace("{{TYPE_COMPTE}}", in_TypeCompte).Replace("{{DATE}}", DateTime.Now.ToString("dd/MM/yyyy"))]</InArgument>
      </Assign.Value>
    </Assign>
